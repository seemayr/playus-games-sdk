{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@playus/games-sdk": ["src/playus/index.ts"],
      "@playus/games-sdk/*": ["src/playus/*"],
      "@playus/*": ["src/playus/*"],
      "@playus": ["src/playus/index.ts"]
    }
  },
  "include": ["src", "games"]
}
